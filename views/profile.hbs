<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hồ Sơ Cá Nhân - GiftShop</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #f0f4f8;
            --bg-secondary: #ffffff;
            --accent-color: #2563eb;
            --accent-hover: #1d4ed8;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border-color: #cbd5e1;
            --success-color: #10b981;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Outfit', sans-serif;
        }

        body {
            background-color: var(--bg-primary);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        header {
            background-color: var(--bg-secondary);
            border-bottom: 1px solid var(--border-color);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
        }

        main {
            flex: 1;
            padding: 3rem 2rem;
            max-width: 600px;
            margin: 0 auto;
            width: 100%;
        }

        .profile-card {
            background-color: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 2.5rem;
            display: flex;
            flex-direction: column;
            gap: 2rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        }

        .avatar-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .avatar-preview {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 2px solid var(--accent-color);
            object-fit: cover;
            background-color: var(--bg-primary);
        }

        .upload-btn-wrapper {
            position: relative;
            overflow: hidden;
            display: inline-block;
        }

        .btn-upload {
            border: 1px dashed var(--accent-color);
            color: var(--accent-color);
            background-color: transparent;
            padding: 8px 20px;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-upload:hover {
            background-color: rgba(37, 99, 235, 0.1);
        }

        .upload-btn-wrapper input[type=file] {
            font-size: 100px;
            position: absolute;
            left: 0;
            top: 0;
            opacity: 0;
            cursor: pointer;
        }

        h2 {
            font-size: 2rem;
            font-weight: 700;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        label {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-muted);
        }

        input {
            background-color: var(--bg-primary);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 0.75rem 1rem;
            border-radius: 8px;
            outline: none;
            transition: border-color 0.3s ease;
        }

        input:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        input:focus:not(:disabled) {
            border-color: var(--accent-color);
        }

        .btn-update {
            background-color: var(--accent-color);
            color: #ffffff;
            border: none;
            padding: 0.75rem;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .btn-update:hover {
            background-color: var(--accent-hover);
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .nav-links a, .nav-links button {
            color: var(--text-main);
            text-decoration: none;
            font-size: 1rem;
            transition: all 0.3s ease;
            background: none;
            border: none;
            cursor: pointer;
        }

        .nav-links a:hover {
            color: var(--accent-color);
        }

        .btn-accent {
            background-color: var(--accent-color) !important;
            color: #ffffff !important;
            padding: 0.5rem 1.2rem;
            border-radius: 8px;
            font-weight: 600;
        }

        .btn-accent:hover {
            background-color: var(--accent-hover) !important;
            transform: translateY(-2px);
        }
    </style>
</head>
<body>
    <header>
        <a href="/" class="logo">GiftShop</a>
        <nav class="nav-links" id="navbar">
            <a href="/">Trang chủ</a>
            <a href="/login" id="loginBtn">Đăng nhập</a>
            <a href="/register" id="registerBtn" class="btn-accent">Đăng ký</a>
        </nav>
    </header>

    <main style="display: flex; flex-direction: column; gap: 2rem; max-width: 800px;">
        <div class="profile-card">
            <h2>Hồ sơ cá nhân</h2>
            
            <!-- Avatar Upload Area -->
            <div class="avatar-container">
                <img id="avatarImg" class="avatar-preview" src="https://www.w3schools.com/howto/img_avatar.png" alt="Avatar">
                <div class="upload-btn-wrapper">
                    <button class="btn-upload">Chọn ảnh mới</button>
                    <input type="file" id="avatarFile" accept="image/*" onchange="uploadAvatar()">
                </div>
            </div>

            <form id="profileForm" onsubmit="updateProfile(event)">
                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label>Email (Tài khoản)</label>
                    <input type="email" id="email" disabled>
                </div>
                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label>Họ và tên</label>
                    <input type="text" id="fullName" required>
                </div>
                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label>Vai trò</label>
                    <input type="text" id="role" disabled>
                </div>
                <button type="submit" class="btn-update">Cập nhật thông tin</button>
            </form>
        </div>

        <!-- Redemption History Card -->
        <div class="profile-card" id="historyCard" style="display: none;">
            <h2>Lịch sử đổi quà</h2>
            <div id="redemptionHistory" style="display: flex; flex-direction: column; gap: 1rem; margin-top: 1rem;">
                <p style="color: var(--text-muted); text-align: center;">Đang tải lịch sử...</p>
            </div>
        </div>
    </main>


    <script>
        const token = localStorage.getItem('accessToken');
        const role = localStorage.getItem('userRole');

        if (!token) {
            window.location.href = '/login';
        }

        // Quản lý trạng thái Navbar dựa vào Token
        async function updateNavbar(avatarUrl, points) {
            const navbar = document.getElementById('navbar');
            if (token) {
                let html = '<a href="/">Trang chủ</a>';
                if (role === 'admin') {
                    html += `
                        <a href="/admin/gifts-management" class="btn-accent" style="display: flex; align-items: center; gap: 8px;">
                            <img src="${avatarUrl}" alt="Avatar" style="width: 24px; height: 24px; border-radius: 50%; object-fit: cover; border: 1px solid #ffffff;">
                            Quản lý quà (Admin)
                        </a>
                    `;
                } else {
                    html += `
                        <span class="user-points-display" style="display: flex; align-items: center; gap: 4px; font-weight: 700; color: #ffffff; background: linear-gradient(135deg, #eab308 0%, #ca8a04 100%); padding: 0.35rem 0.8rem; border-radius: 999px; font-size: 0.9rem; box-shadow: 0 4px 6px -1px rgba(234, 179, 8, 0.2);">
                            🪙 ${points} Điểm
                        </span>
                        <a href="/profile" style="display: flex; align-items: center; gap: 8px;">
                            <img src="${avatarUrl}" alt="Avatar" style="width: 30px; height: 30px; border-radius: 50%; object-fit: cover; border: 1px solid var(--accent-color);">
                            Hồ sơ cá nhân
                        </a>
                    `;
                }
                html += '<button onclick="logout()" class="btn-accent" style="margin-left:10px;">Đăng xuất</button>';
                navbar.innerHTML = html;
            }
        }

        function logout() {
            localStorage.removeItem('accessToken');
            localStorage.removeItem('userRole');
            localStorage.removeItem('userPoints');
            window.location.href = '/';
        }

        // Tải thông tin Profile cá nhân
        async function fetchProfile() {
            try {
                const response = await fetch('/api/v1/users/profile', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                
                if (response.status === 401) {
                    localStorage.clear();
                    window.location.href = '/login';
                    return;
                }

                const data = await response.json();
                document.getElementById('email').value = data.email;
                document.getElementById('fullName').value = data.fullName;
                document.getElementById('role').value = data.role.toUpperCase();
                
                // Lưu points & role vào localStorage
                localStorage.setItem('userPoints', data.points);
                localStorage.setItem('userRole', data.role);

                const avatarUrl = data.avatar || 'https://www.w3schools.com/howto/img_avatar.png';
                document.getElementById('avatarImg').src = avatarUrl;

                updateNavbar(avatarUrl, data.points);

                // Nếu là user, tải lịch sử đổi quà
                if (data.role === 'user') {
                    document.getElementById('historyCard').style.display = 'block';
                    fetchRedemptionHistory();
                }
            } catch (err) {
                console.error(err);
            }
        }

        // Tải lịch sử đổi quà của user
        async function fetchRedemptionHistory() {
            try {
                const response = await fetch('/api/v1/redemptions', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if (response.ok) {
                    const result = await response.json();
                    const historyContainer = document.getElementById('redemptionHistory');
                    const redemptions = result.data || [];
                    
                    if (redemptions.length === 0) {
                        historyContainer.innerHTML = '<p style="color:var(--text-muted); text-align:center; padding: 1rem 0;">Bạn chưa có giao dịch đổi quà nào.</p>';
                        return;
                    }
                    
                    historyContainer.innerHTML = redemptions.map(r => {
                        const giftName = r.gift ? r.gift.name : 'Quà đã bị xóa hoặc ẩn';
                        const date = new Date(r.createdAt).toLocaleString('vi-VN');
                        
                        let statusColor = 'var(--success-color)';
                        let statusText = 'Hoàn thành';
                        if (r.status === 'pending') {
                            statusColor = 'orange';
                            statusText = 'Đang xử lý';
                        } else if (r.status === 'cancelled') {
                            statusColor = 'var(--error-color)';
                            statusText = 'Đã hủy';
                        }
                        
                        return `
                            <div style="border: 1px solid var(--border-color); padding: 1rem; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; background: #f8fafc; transition: transform 0.2s ease;">
                                <div>
                                    <div style="font-weight: 600; font-size: 1.05rem;">${giftName}</div>
                                    <div style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.25rem;">${date}</div>
                                </div>
                                <div style="text-align: right;">
                                    <div style="font-weight: 700; color: var(--accent-color); font-size: 1.1rem;">-${r.pointsUsed} Điểm</div>
                                    <div style="font-size: 0.85rem; color: ${statusColor}; font-weight: 600; margin-top: 0.25rem;">● ${statusText}</div>
                                </div>
                            </div>
                        `;
                    }).join('');
                }
            } catch (e) {
                console.error('Không thể tải lịch sử đổi quà', e);
            }
        }

        // Tải lên avatar mới
        async function uploadAvatar() {
            const fileInput = document.getElementById('avatarFile');
            const file = fileInput.files[0];
            if (!file) return;

            const formData = new FormData();
            formData.append('file', file);

            try {
                const response = await fetch('/api/v1/users/upload/avatar', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`
                    },
                    body: formData
                });

                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.message || 'Tải ảnh đại diện thất bại');
                }

                alert('Cập nhật ảnh đại diện thành công!');
                fetchProfile();
            } catch (err) {
                alert(err.message);
            } finally {
                fileInput.value = '';
            }
        }

        // Cập nhật Profile cá nhân
        async function updateProfile(e) {
            e.preventDefault();
            const fullName = document.getElementById('fullName').value;

            try {
                const response = await fetch('/api/v1/users/profile', {
                    method: 'PATCH',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({ fullName })
                });

                if (response.ok) {
                    alert('Cập nhật thông tin profile thành công!');
                    fetchProfile();
                } else {
                    const data = await response.json();
                    throw new Error(data.message || 'Cập nhật không thành công');
                }
            } catch (err) {
                alert(err.message);
            }
        }

        fetchProfile();
    </script>
</body>
</html>
